# ── Supabase (stesso DB per Vercel UI + Hetzner batch) ──
# Vercel: usa la connection string "Transaction pooler" (porta 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrazioni / Hetzner batch: connection string "Direct" (porta 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

TAVILY_API_KEY=tvly-...

# Opzionale: scan produzione Hetzner
# SCAN_CONCURRENCY=8
# POLICY_EXHAUSTIVE=1
# OCR_ENABLED=1
