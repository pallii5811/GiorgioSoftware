// LeadSniper — PostgreSQL (Supabase) in produzione; Hetzner batch + Vercel UI stesso DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id              String   @id @default(cuid())
  type            String   // "HEALTHCARE" or "TENDER"
  companyName     String
  region          String   // "Campania" o "Veneto"
  status          String   @default("NEW") // "NEW", "CONTACTED", "CONVERTED", "LOST"

  // Dati specifici per Case di Cura (Sanità)
  osmId            String?   @unique
  website          String?
  city             String?
  phone            String?
  email            String?
  pec              String?
  piva             String?
  leadScore        Int?      @default(0)
  category         String?
  policyFound      Boolean?  @default(false)
  policyCompany    String?
  policyMassimale  String?
  policyNumber     String?
  policyExpiry     DateTime?
  confidence       Float?
  evidence         String?
  notes            String?
  reminderAt       DateTime?
  websiteReachable Boolean?
  pagesVisited     Int?      @default(0)
  lastScannedAt    DateTime?

  // Dati specifici per Gare (Tenders)
  tenderCig       String?  @unique
  tenderAmount    Float?
  tenderObject    String?
  tenderWinner    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type, region])
  @@index([type, region, lastScannedAt])
  @@index([region, companyName])
}
